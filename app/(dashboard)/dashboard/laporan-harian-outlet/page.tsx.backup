'use client';

import { useState, useEffect, useCallback } from 'react';
import { 
  TrendingUp, 
  TrendingDown, 
  DollarSign, 
  ShoppingCart, 
  Package, 
  AlertCircle, 
  RefreshCw, 
  Calendar,
  Users,
  CreditCard,
  Award,
  AlertTriangle,
  CheckCircle2,
  XCircle,
  Clock,
  BarChart3,
  PieChart,
  Activity
} from 'lucide-react';

type UkuranDonat = 'standar' | 'mini';

// ══════════════════════════════════════════
// REAL DATA TYPES - Laporan Outlet Real-Time
// ══════════════════════════════════════════

interface ProdukHarian {
  id: string;
  nama: string;
  ukuran: UkuranDonat;
  hargaJual: number;
  hpp: number;
  diproduksi: number;
  terjual: number;
  gagalProduksi: number;
  batalBeli: number;
  sisaBertoping: number;
  sisaTanpaToping: number;
}

interface PengeluaranItem {
  id: string;
  kategori: string;
  keterangan: string;
  jumlah: number;
}

interface TransaksiKasir {
  id: string;
  waktu: string;
  kasir: string;
  namaPelanggan: string;
  totalItem: number;
  totalHarga: number;
  metodeBayar: string;
}

// ══════════════════════════════════════════
// HELPERS - Get Outlet & User Info
// ══════════════════════════════════════════

function getOutletIdFromStorage(): string {
  if (typeof window === 'undefined') return '';
  
  // Try multiple storage sources - the main key is 'donutshop_user'
  try {
    // Try 'donutshop_user' key (main auth key)
    const userStr = localStorage.getItem('donutshop_user');
    if (userStr) {
      const user = JSON.parse(userStr);
      if (user.outlet_id) return user.outlet_id;
    }
    
    // Try 'user' key (fallback)
    const userStr2 = localStorage.getItem('user');
    if (userStr2) {
      const user = JSON.parse(userStr2);
      if (user.outlet_id) return user.outlet_id;
    }
    
    // Try 'kasir_outlet' key (kasir context)
    const outletStr = localStorage.getItem('kasir_outlet');
    if (outletStr) {
      const outlet = JSON.parse(outletStr);
      if (outlet.id) return outlet.id;
    }
    
    // Try 'outlet_id' directly
    const outletId = localStorage.getItem('outlet_id');
    if (outletId) return outletId;
  } catch (e) {
    console.warn('Error getting outlet ID from storage:', e);
  }
  
  return '';
}

function getUserFromStorage(): any {
  if (typeof window === 'undefined') return null;
  
  try {
    // Try 'donutshop_user' key (main auth key)
    const userStr = localStorage.getItem('donutshop_user');
    if (userStr) {
      return JSON.parse(userStr);
    }
    
    // Try 'user' key (fallback)
    const userStr2 = localStorage.getItem('user');
    if (userStr2) {
      return JSON.parse(userStr2);
    }
    
    // Try 'kasir_user' key (kasir context)
    const kasirUserStr = localStorage.getItem('kasir_user');
    if (kasirUserStr) {
      return JSON.parse(kasirUserStr);
    }
  } catch (e) {
    console.warn('Error getting user from storage:', e);
  }
  
  return null;
}

// ══════════════════════════════════════════
// REAL-TIME DATA FETCHERS
// ══════════════════════════════════════════

/**
 * Fetch production data for today from the API
 * This replaces the hardcoded PRODUK_DATA
 */
async function fetchProductionData(outletId: string): Promise<ProdukHarian[]> {
  try {
    const today = new Date().toISOString().split('T')[0];
    const user = getUserFromStorage();
    
    console.log('[fetchProductionData] Starting fetch for:', { outletId, today, userId: user?.id });
    
    const response = await fetch(`/api/production/daily?outlet_id=${outletId}&tanggal=${today}`, {
      method: 'GET',
      headers: {
        'x-user-id': user?.id || '',
        'x-user-role': user?.role || '',
        'x-outlet-id': outletId,
      },
    });

    console.log('[fetchProductionData] Response status:', response.status);

    if (!response.ok) {
      console.error('Failed to fetch production data:', response.statusText);
      // Return fallback data
      return getFallbackProductionData();
    }

    const result = await response.json();
    console.log('[fetchProductionData] API result:', result);
    
    if (!result.success) {
      console.error('API error:', result.error);
      return getFallbackProductionData();
    }

    // Transform production data to match ProdukHarian interface
    const items = result.data?.items || [];
    console.log('[fetchProductionData] Items received:', items.length);
    
    if (items.length === 0) {
      return getFallbackProductionData();
    }

    const aggregated = new Map<string, ProdukHarian>();

    items.forEach((item: any) => {
      const key = `${item.ukuran}`;
      if (!aggregated.has(key)) {
        aggregated.set(key, {
          id: item.id,
          nama: item.ukuran === 'standar' ? 'Standar Produk' : 'Mini Produk',
          ukuran: item.ukuran,
          hargaJual: 0,
          hpp: 0,
          diproduksi: 0,
          terjual: 0,
          gagalProduksi: 0,
          batalBeli: 0,
          sisaBertoping: 0,
          sisaTanpaToping: 0,
        });
      }

      const existing = aggregated.get(key)!;
      existing.diproduksi += item.target_qty || 0;
      existing.terjual += item.success_qty || 0;
      existing.gagalProduksi += item.waste_qty || 0;
    });

    return Array.from(aggregated.values());
  } catch (error) {
    console.error('[fetchProductionData] Error:', error);
    return getFallbackProductionData();
  }
}


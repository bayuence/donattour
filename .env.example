# Donattour POS - Environment Configuration Template

# ============================================================================
# SUPABASE Configuration
# ============================================================================
# Get these from: https://app.supabase.co → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# SENTRY Error Tracking (Optional - Free tier available)
# ============================================================================
# Setup: https://sentry.io/signup → Create project "donattour-pos"
# Get DSN from: Settings → Projects → Your Project → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345
SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org-name
SENTRY_PROJECT=donattour-pos

# ============================================================================
# MIDTRANS Payment Gateway
# ============================================================================
# Setup: https://dashboard.midtrans.com
# Sandbox or Production credentials depending on NODE_ENV
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_SERVER_KEY=your-midtrans-server-key

# ============================================================================
# GOOGLE SHEETS Integration
# ============================================================================
# Setup: Google Cloud Console → Create service account → Export JSON
GOOGLE_SHEETS_ACCESS_TOKEN=your-google-sheets-access-token
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# ============================================================================
# HEALTH CHECK Monitoring
# ============================================================================
# Random secret to prevent unauthorized health checks
HEALTH_CHECK_SECRET=generate-random-string-here

# ============================================================================
# LOGGING Configuration
# ============================================================================
# Options: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Options: development, production
NODE_ENV=production

# ============================================================================
# DEPLOYMENT (Vercel specific)
# ============================================================================
# Vercel automatically handles these, but useful for local testing
VERCEL_ENV=production
VERCEL_URL=your-vercel-deployment-url.vercel.app
